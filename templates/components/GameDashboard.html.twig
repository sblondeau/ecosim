{% import 'game/_macros.html.twig' as ui %}
{% set game = this.game %}
{% set speed = this.speedValue %}
{% set selected = this.selectedSlot %}
{% set slots = ['roof', 'walls', 'heating', 'garage', 'living'] %}
{# Welcome overlay: a brand-new game (day 1), until the player dismisses it.
   While it is up the clock is frozen (no data-poll), so reading it costs no days. #}
{% set showIntro = not this.introDismissed and game.dayNumber == 1 and not game.finished %}
<div{{ attributes }} class="game{{ game.finished ? ' is-finished' }}" {% if not game.finished and not showIntro %}data-poll="delay(4000)|$render"{% endif %}>
    <header class="top">
        <div class="brand">
            <h1>🏠 EcoSim</h1>
            <div class="sub">Jour {{ game.dayNumber }} / {{ game.horizonDays }} · {{ game.dateLabel }} · {{ game.seasonLabel }}</div>
        </div>
        <div class="progress"><span style="width: {{ game.progressPct }}%"></span></div>
        {% if not game.finished %}
            <div class="time-controls">
                <div class="speed">
                    <button type="button" class="btn-ghost btn-small {{ speed == 0 ? 'active' }}" title="Pause"
                            data-action="live#action" data-live-action-param="setSpeed" data-live-speed-param="0">⏸</button>
                    <button type="button" class="btn-ghost btn-small {{ speed == 1 ? 'active' }}" title="Vitesse normale (1 jour / 12 s)"
                            data-action="live#action" data-live-action-param="setSpeed" data-live-speed-param="1">▶ ×1</button>
                    <button type="button" class="btn-ghost btn-small {{ speed == 2 ? 'active' }}" title="1 jour / 6 s"
                            data-action="live#action" data-live-action-param="setSpeed" data-live-speed-param="2">×2</button>
                    <button type="button" class="btn-ghost btn-small {{ speed == 3 ? 'active' }}" title="1 jour / 4 s"
                            data-action="live#action" data-live-action-param="setSpeed" data-live-speed-param="3">×3</button>
                </div>
                <button type="button" class="btn-primary btn-small"
                        data-action="live#action" data-live-action-param="step">Jour suivant →</button>
            </div>
        {% endif %}
    </header>

    {% if this.notice is not empty %}
        <div class="banner {{ this.noticeIsError ? '' : 'banner-ok' }}">{{ this.noticeIsError ? '⚠️' : '✅' }} {{ this.notice }}</div>
    {% endif %}

    {% if game.boilerBroken and not game.finished %}
        <div class="banner">🚨 La chaudière fioul est en panne. Vos chauffages d'appoint électriques maintiennent péniblement ~16 °C — et l'électricité flambe (effet Joule : 1 kWh consommé = 1 kWh de chaleur, le pire des chauffages). Cliquez la chaudière pour réparer ou remplacer.{% if speed == 0 %} Le temps est en pause, décidez sereinement — puis relancez (▶).{% endif %}</div>
    {% endif %}

    <div class="stage">
        {{ include('game/scene/_cutaway.html.twig') }}

        {# ===== HUD permanent superposé (info directe in-game) ===== #}
        <div class="hud hud-tl card">
            <div class="hud-title">Épargne</div>
            <div class="big {{ game.savingsNegative ? 'neg' }}">{{ game.savingsLabel }}</div>
            <div class="hud-line"><span class="k">Aujourd'hui</span><span class="{{ game.dayNetNegative ? 'neg' : 'pos' }}">{{ game.dayNetLabel }}</span></div>
            {% if game.loanActive %}<div class="hud-line"><span class="k">Dette éco-PTZ · {{ game.loanRemainingYears }} an{{ game.loanRemainingYears > 1 ? 's' }}</span><span>{{ game.loanRemainingLabel }}</span></div>{% endif %}
            {% if game.inFuelPoverty %}<div class="precarity-badge">⚠️ Précarité énergétique · {{ game.energyEffortPct }} %</div>{% endif %}
        </div>

        <div class="hud hud-tr card">
            <div class="hud-line"><span class="k">🌡️</span><span>{{ game.temperatureC|number_format(1, ',', ' ') }} °C</span></div>
            <div class="hud-line"><span class="k">☁️</span><span>{{ game.cloudPct }} %</span></div>
            <div class="hud-line"><span class="k">🛋️ Confort</span><span>{{ game.comfortScorePct }} %</span></div>
            <div class="gauge"><span style="width: {{ game.comfortScorePct }}%; background: var(--accent);"></span></div>
        </div>

        <div class="hud hud-bl card">
            <div class="hud-line"><span class="k">⚡ Prod. / conso</span><span>{{ game.productionKwh|number_format(1, ',', ' ') }} / {{ game.demandKwh|number_format(1, ',', ' ') }} kWh</span></div>
            <div class="hud-line"><span class="k">🔄 Autosuffisance</span><span>{{ game.selfSufficiencyPct }} %</span></div>
            {% if game.fuelOilLitres > 0 %}<div class="hud-line"><span class="k">🛢️ Fioul</span><span>{{ game.fuelOilLitres|number_format(1, ',', ' ') }} L</span></div>{% endif %}
        </div>

        <button type="button" class="hud hud-br btn-ghost btn-small {{ selected == 'menu' ? 'active' }}"
                data-action="click->live#action" data-live-action-param="selectSlot" data-live-slot-param="menu">≡ Bilan & options</button>

        {# ===== écran de bienvenue (premier lancement) ===== #}
        {% if showIntro %}
            <div class="intro-overlay">
                <div class="intro-card">
                    <h2>🏠 Bienvenue chez vous</h2>
                    <p class="lead">Vous êtes primo-accédant. Vous venez d'emménager dans une <strong>maison ancienne chauffée au fioul, classée DPE&nbsp;F</strong>, avec une épargne modeste.</p>
                    <p class="intro-goal">Vivez-y un an. <strong>Il n'y a pas de partie perdue</strong> : à vous d'équilibrer vos trois axes.</p>
                    <ul class="intro-axes">
                        <li><span class="ax">💶</span> <span><strong>Finances</strong> — épargne, factures d'énergie, aides et prêt.</span></li>
                        <li><span class="ax">🏠</span> <span><strong>Patrimoine</strong> — la classe DPE et la valeur du bien.</span></li>
                        <li><span class="ax">🛋️</span> <span><strong>Confort</strong> — la température <em>ressentie</em> chez vous.</span></li>
                    </ul>
                    <p class="intro-how">Cliquez le <strong>toit</strong>, la <strong>chaudière</strong>, le <strong>garage</strong> ou le <strong>séjour</strong> pour agir. Le temps avance seul — <strong>⏸</strong> pour réfléchir. Des imprévus peuvent survenir.</p>
                    <button type="button" class="btn-primary"
                            data-action="live#action" data-live-action-param="dismissIntro">Commencer →</button>
                </div>
            </div>
        {% endif %}

        {# ===== panneau flottant contextuel (au clic sur un élément) ===== #}
        {% if selected %}
            <button type="button" class="panel-backdrop" aria-label="Fermer"
                    data-action="click->live#action" data-live-action-param="closePanel"></button>
            <aside class="float-panel">
                <button type="button" class="float-close btn-ghost btn-small"
                        data-action="click->live#action" data-live-action-param="closePanel" aria-label="Fermer">✕</button>
                {% if selected == 'menu' %}
                    {{ include('game/panel/_summary.html.twig') }}
                {% elseif selected in slots %}
                    {{ include('game/panel/_slot.html.twig') }}
                {% endif %}
            </aside>
        {% endif %}
    </div>

    {% if game.endReport %}
        {% set report = game.endReport %}
        <section class="end-report">
            <div class="banner banner-ok">🏁 Fin de partie — un an dans votre maison. Voici les faits, axe par axe.</div>
            <div class="grid">
                <div class="card">
                    <h2>Finances</h2>
                    <div class="row"><span class="k">Épargne au départ</span><span>{{ report.savingsStartLabel }}</span></div>
                    <div class="row"><span class="k">Épargne à la fin</span><span>{{ report.savingsEndLabel }}</span></div>
                    <div class="row"><span class="k">Évolution</span><span class="{{ report.savingsDeltaNegative ? 'neg' : 'pos' }}"><strong>{{ report.savingsDeltaLabel }}</strong></span></div>
                </div>
                <div class="card">
                    <h2>Patrimoine</h2>
                    <div class="row"><span class="k">DPE</span><span>{{ report.dpeStartLetter }} → <strong>{{ report.dpeEndLetter }}</strong></span></div>
                    <div class="row"><span class="k">Valeur du bien</span><span>{{ report.propertyStartLabel }} → {{ report.propertyEndLabel }}</span></div>
                    <div class="row"><span class="k">Évolution</span><span><strong>{{ report.propertyDeltaLabel }}</strong> <span class="k">(réalisable à la revente uniquement)</span></span></div>
                    {% if report.loanActive %}
                        <div class="row"><span class="k">Éco-PTZ restant à rembourser</span><span class="neg">{{ report.loanRemainingLabel }}</span></div>
                    {% endif %}
                </div>
                <div class="card">
                    <h2>Confort</h2>
                    <div class="big">{{ report.averageComfortPct }} %</div>
                    <div class="row"><span class="k">Confort thermique moyen sur l'année</span><span></span></div>
                </div>
                <div class="card">
                    <h2>Énergie</h2>
                    <div class="row"><span class="k">Fioul consommé</span><span>{{ report.totalFuelOilLitres|number_format(1, ',', ' ') }} L</span></div>
                    <div class="row"><span class="k">Autosuffisance électrique</span><span>{{ report.totalSelfSufficiencyPct }} %</span></div>
                    <div class="row"><span class="k">Coût énergie net sur l'année</span><span>{{ report.totalNetEnergyCostLabel }}</span></div>
                </div>
            </div>
            <button type="button" class="btn-primary" style="margin-top:1rem"
                    data-action="live#action" data-live-action-param="reset">Nouvelle partie</button>
        </section>
    {% endif %}
</div>
