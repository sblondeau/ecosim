{% set game = this.game %}
{% set speed = this.speedValue %}
{% set selected = this.selectedSlot %}
{% set slots = ['roof', 'walls', 'heating', 'garage', 'living'] %}
{# Focused panels anchored to the corner they belong to (slots default to ↘). #}
{% set panelPos = {finances: 'at-tl', comfort: 'at-tr', energy: 'at-bl', patrimoine: 'at-br', weather: 'at-top', options: 'at-bottom'} %}
{# Welcome overlay: a brand-new game (day 1), until dismissed. Freezes the clock. #}
{% set showIntro = not this.introDismissed and game.dayNumber == 1 and not game.finished %}
<div{{ attributes }} class="game{{ game.finished ? ' is-finished' }}" {% if not game.finished and not showIntro %}data-poll="delay(4000)|$render"{% endif %}>
    <div class="stage">
        {{ include('game/scene/_cutaway.html.twig') }}

        {# progression de l'année : ligne fine tout en haut #}
        <div class="year-progress"><span style="width: {{ game.progressPct }}%"></span></div>

        {# puce météo (haut-centre) : le contexte du jour, ouvre son évolution #}
        <button type="button" class="weather-chip{{ selected == 'weather' ? ' active' }}" title="Météo & évolution"
                data-action="click->live#action" data-live-action-param="selectSlot" data-live-slot-param="weather">{{ game.seasonLabel }} · 🌡️{{ game.temperatureC|number_format(1, ',', ' ') }}° · ☁{{ game.cloudPct }}%</button>

        {# bandeaux transitoires, centrés au-dessus de la scène #}
        {% if this.notice is not empty %}
            <div class="stage-banner banner {{ this.noticeIsError ? '' : 'banner-ok' }}">{{ this.noticeIsError ? '⚠️' : '✅' }} {{ this.notice }}</div>
        {% elseif game.boilerBroken and not game.finished %}
            <div class="stage-banner banner">🚨 Chaudière en panne — appoint électrique forcé (~16 °C), l'électricité flambe. Cliquez la chaudière pour réparer ou remplacer.{% if speed == 0 %} Temps en pause (▶ pour relancer).{% endif %}</div>
        {% endif %}

        {# ===== 4 coins = 4 axes (clic → panneau focalisé) ===== #}
        <div class="hud hud-tl card" role="button" tabindex="0" title="Finances — détails"
             data-action="click->live#action" data-live-action-param="selectSlot" data-live-slot-param="finances">
            <div class="hud-title">💶 Finances</div>
            <div class="big {{ game.savingsNegative ? 'neg' }}">{{ game.savingsLabel }}</div>
            <div class="hud-line"><span class="key">Aujourd'hui</span><span class="{{ game.dayNetNegative ? 'neg' : 'pos' }}">{{ game.dayNetLabel }}</span></div>
            {% if game.inFuelPoverty %}<div class="precarity-badge">⚠️ Précarité · {{ game.energyEffortPct }} %</div>{% endif %}
        </div>

        <div class="hud hud-tr card" role="button" tabindex="0" title="Confort — détails"
             data-action="click->live#action" data-live-action-param="selectSlot" data-live-slot-param="comfort">
            <div class="hud-title">🛋️ Confort</div>
            <div class="big">{{ game.comfortScorePct }} %</div>
            <div class="gauge"><span style="width: {{ game.comfortScorePct }}%; background: var(--accent);"></span></div>
        </div>

        <div class="hud hud-bl card" role="button" tabindex="0" title="Énergie & climat — détails"
             data-action="click->live#action" data-live-action-param="selectSlot" data-live-slot-param="energy">
            <div class="hud-title">⚡ Énergie & climat</div>
            <div class="hud-line"><span class="key">Prod. / conso</span><span>{{ game.productionKwh|number_format(1, ',', ' ') }} / {{ game.demandKwh|number_format(1, ',', ' ') }} kWh</span></div>
            <div class="hud-line"><span class="key">CO₂ logement</span><span>{{ game.dpeClimateIntensity }} kgCO₂/m²·an</span></div>
        </div>

        <div class="hud hud-br card" role="button" tabindex="0" title="Patrimoine — étiquette DPE"
             data-action="click->live#action" data-live-action-param="selectSlot" data-live-slot-param="patrimoine">
            <div class="hud-title">🏠 Patrimoine</div>
            <div class="dpe-chip dpe-e-{{ game.dpeLetter|lower }}">DPE {{ game.dpeLetter }}</div>
        </div>

        {# ===== écran de bienvenue (premier lancement) ===== #}
        {% if showIntro %}
            <div class="intro-overlay">
                <div class="intro-card">
                    <h2>🏠 Bienvenue chez vous</h2>
                    <p class="lead">Vous êtes primo-accédant. Vous venez d'emménager dans une <strong>maison ancienne chauffée au fioul, classée DPE&nbsp;F</strong>, avec une épargne modeste.</p>
                    <p class="intro-goal">Vivez-y un an. <strong>Il n'y a pas de partie perdue</strong> : à vous d'équilibrer vos trois axes.</p>
                    <ul class="intro-axes">
                        <li><span class="ax">💶</span> <span><strong>Finances</strong> — épargne, factures d'énergie, aides et prêt.</span></li>
                        <li><span class="ax">🏠</span> <span><strong>Patrimoine</strong> — la classe DPE et la valeur du bien.</span></li>
                        <li><span class="ax">🛋️</span> <span><strong>Confort</strong> — la température <em>ressentie</em> chez vous.</span></li>
                    </ul>
                    <p class="intro-how">Cliquez le <strong>toit</strong>, la <strong>chaudière</strong>, le <strong>garage</strong> ou le <strong>séjour</strong> pour agir, et les <strong>quatre coins</strong> pour vos indicateurs. Le temps avance seul — <strong>⏸</strong> pour réfléchir. Des imprévus peuvent survenir.</p>
                    <twig:Button label="Commencer →" action="dismissIntro" class="btn-primary" />
                </div>
            </div>
        {% endif %}

        {# bandeau de contrôle bas-centre : date · saison · météo · vitesse · jour+ #}
        {% if not game.finished %}
            <div class="controlbar">
                <div class="cb-when">Jour {{ game.dayNumber }}/{{ game.horizonDays }} · {{ game.dateLabel }}</div>
                <div class="speed">
                    <twig:Button label="⏸" action="setSpeed" :params="{speed: 0}" title="Pause" :active="speed == 0" />
                    <twig:Button label="▶" action="setSpeed" :params="{speed: 1}" title="1 jour / 12 s" :active="speed == 1" />
                    <twig:Button label="×2" action="setSpeed" :params="{speed: 2}" title="1 jour / 6 s" :active="speed == 2" />
                    <twig:Button label="×3" action="setSpeed" :params="{speed: 3}" title="1 jour / 4 s" :active="speed == 3" />
                </div>
                <twig:Button label="Jour suivant →" action="step" class="btn-primary btn-small" />
                <twig:Button label="⚙" action="selectSlot" :params="{slot: 'options'}" class="gear" :active="selected == 'options'" title="Options & bilan de session" />
            </div>
        {% endif %}

    </div>

    {# panneau focalisé — HORS du .stage (qui a overflow:hidden) pour que les
       infobulles débordent librement ; positionné dans le .game #}
    {% if selected %}
        <button type="button" class="panel-backdrop" aria-label="Fermer"
                data-action="click->live#action" data-live-action-param="closePanel"></button>
        <aside class="float-panel {{ panelPos[selected] ?? 'at-br' }}">
            {% if selected in slots %}
                {{ include('game/panel/_slot.html.twig') }}
            {% elseif selected == 'finances' %}
                {{ include('game/panel/_finances.html.twig') }}
            {% elseif selected == 'comfort' %}
                {{ include('game/panel/_comfort.html.twig') }}
            {% elseif selected == 'energy' %}
                {{ include('game/panel/_energy.html.twig') }}
            {% elseif selected == 'patrimoine' %}
                {{ include('game/panel/_patrimoine.html.twig') }}
            {% elseif selected == 'weather' %}
                {{ include('game/panel/_weather.html.twig') }}
            {% elseif selected == 'options' %}
                {{ include('game/panel/_options.html.twig') }}
            {% endif %}
        </aside>
    {% endif %}

    {% if game.endReport %}
        {% set report = game.endReport %}
        <section class="end-report">
            <div class="banner banner-ok">🏁 Fin de partie — un an dans votre maison. Voici les faits, axe par axe.</div>
            <div class="grid">
                <div class="card">
                    <h2>Finances</h2>
                    <div class="row"><span class="key">Épargne au départ</span><span>{{ report.savingsStartLabel }}</span></div>
                    <div class="row"><span class="key">Épargne à la fin</span><span>{{ report.savingsEndLabel }}</span></div>
                    <div class="row"><span class="key">Évolution</span><span class="{{ report.savingsDeltaNegative ? 'neg' : 'pos' }}"><strong>{{ report.savingsDeltaLabel }}</strong></span></div>
                </div>
                <div class="card">
                    <h2>Patrimoine</h2>
                    <div class="row"><span class="key">DPE</span><span>{{ report.dpeStartLetter }} → <strong>{{ report.dpeEndLetter }}</strong></span></div>
                    <div class="row"><span class="key">Valeur du bien</span><span>{{ report.propertyStartLabel }} → {{ report.propertyEndLabel }}</span></div>
                    <div class="row"><span class="key">Évolution</span><span><strong>{{ report.propertyDeltaLabel }}</strong> <span class="key">(réalisable à la revente uniquement)</span></span></div>
                    {% if report.loanActive %}
                        <div class="row"><span class="key">Éco-PTZ restant à rembourser</span><span class="neg">{{ report.loanRemainingLabel }}</span></div>
                    {% endif %}
                </div>
                <div class="card">
                    <h2>Confort</h2>
                    <div class="big">{{ report.averageComfortPct }} %</div>
                    <div class="row"><span class="key">Confort thermique moyen sur l'année</span><span></span></div>
                </div>
                <div class="card">
                    <h2>Énergie</h2>
                    <div class="row"><span class="key">Fioul consommé</span><span>{{ report.totalFuelOilLitres|number_format(1, ',', ' ') }} L</span></div>
                    <div class="row"><span class="key">Autosuffisance électrique</span><span>{{ report.totalSelfSufficiencyPct }} %</span></div>
                    <div class="row"><span class="key">Coût énergie net sur l'année</span><span>{{ report.totalNetEnergyCostLabel }}</span></div>
                </div>
            </div>
            <div style="margin-top: 1rem"><twig:Button label="Nouvelle partie" action="reset" class="btn-primary" /></div>
        </section>
    {% endif %}
</div>
