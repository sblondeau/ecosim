{# Devis de travaux (composant Twig anonyme) : coût, prime, reste à charge,
   effets estimés, et les deux financements en <twig:Button>. `action` =
   l'ActionView. L'aperçu (icône) est le même asset SVG que la scène quand il
   existe (solaire/PAC/chaudière/batterie) ; l'isolation n'a pas d'équipement
   posable dans la scène donc son icône est un petit swatch dédié. #}
{% props action %}
<div class="card quote">
    <p class="quote-eyebrow">Travaux disponibles</p>
    <div class="quote-head">
        <div class="quote-icon">
            {% if action.work == 'solar_panels' %}
                {{ include('game/scene/assets/solar-panels.svg') }}
            {% elseif action.work == 'heat_pump' %}
                {{ include('game/scene/assets/heat-pump.svg') }}
            {% elseif action.work == 'boiler_repair' %}
                {{ include('game/scene/assets/boiler-fioul.svg') }}
            {% elseif action.work == 'pellet_boiler' %}
                {# Même chaudière, teinte bois (filtre CSS) : pas d'asset dédié pour un
                   simple changement de combustible (fioul → granulés). #}
                <div class="quote-icon-wood">{{ include('game/scene/assets/boiler-fioul.svg') }}</div>
            {% elseif action.work == 'low_temp_emitters' %}
                <svg viewBox="0 0 80 80" overflow="visible">
                    <rect x="6" y="50" width="68" height="22" rx="3" fill="#8a7458"/>
                    <path d="M12 60 h8 v-10 h8 v10 h8 v-10 h8 v10 h8 v-10 h8 v10 h8"
                          fill="none" stroke="#e05341" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"/>
                    <path d="M12 60 h8 v-10 h8 v10 h8 v-10 h8 v10 h8 v-10 h8 v10 h8"
                          fill="none" stroke="#f6b199" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" opacity=".7"/>
                </svg>
            {% elseif action.work == 'home_battery' %}
                {{ include('game/scene/assets/battery.svg') }}
            {% elseif action.work in ['roof_insulation', 'wall_insulation_interior', 'wall_insulation_exterior'] %}
                <svg viewBox="0 0 80 80" overflow="visible">
                    <rect x="8" y="8" width="64" height="64" rx="6" fill="#8a7458"/>
                    <rect x="14" y="14" width="52" height="52" rx="3" fill="#69b585"/>
                    <path d="M14 24h52M14 34h52M14 44h52M14 54h52" stroke="#5f9c74" stroke-width="3" opacity=".6"/>
                    <path d="M22 14v52M32 14v52M42 14v52M52 14v52M62 14v52" stroke="#5f9c74" stroke-width="2" opacity=".35"/>
                </svg>
            {% elseif action.work == 'glazing' %}
                <svg viewBox="0 0 80 80" overflow="visible">
                    <rect x="12" y="10" width="56" height="60" rx="4" fill="#7d8ea0"/>
                    <rect x="18" y="16" width="44" height="48" rx="2" fill="#bfe0ee" opacity=".85"/>
                    <path d="M40 16v48M18 40h44" stroke="#7d8ea0" stroke-width="4"/>
                    <path d="M24 22l12 12" stroke="#fff" stroke-width="2" opacity=".6"/>
                </svg>
            {% elseif action.work == 'ventilation_double_flow' %}
                {# VMC double flux : boîtier échangeur + flux d'air entrant/sortant. #}
                <svg viewBox="0 0 80 80" overflow="visible">
                    <rect x="20" y="26" width="40" height="28" rx="4" fill="#8a7458"/>
                    <circle cx="40" cy="40" r="9" fill="none" stroke="#e7e2d8" stroke-width="3"/>
                    <path d="M40 33v14M33 40h14" stroke="#e7e2d8" stroke-width="2"/>
                    <path d="M10 20 q10 6 10 20 t-10 20" fill="none" stroke="#69b585" stroke-width="3" stroke-linecap="round"/>
                    <path d="M70 20 q-10 6 -10 20 t10 20" fill="none" stroke="#e05341" stroke-width="3" stroke-linecap="round" opacity=".8"/>
                </svg>
            {% elseif action.work == 'solar_kit' %}
                {# Kit plug-and-play : un seul petit panneau + une prise (pas d'installateur). #}
                <svg viewBox="0 0 80 80" overflow="visible">
                    <rect x="16" y="24" width="36" height="24" rx="2" fill="#2f4a63"/>
                    <path d="M16 32h36M16 40h36M28 24v24M40 24v24" stroke="#5a7a9a" stroke-width="1.5"/>
                    <circle cx="62" cy="54" r="10" fill="none" stroke="#c9a24b" stroke-width="3"/>
                    <path d="M58 54h8M62 50v8" stroke="#c9a24b" stroke-width="2.5" stroke-linecap="round"/>
                </svg>
            {% elseif action.work == 'water_heater_thermo' %}
                {# Ballon thermodynamique : cuve + ondes de chaleur pompées (petite PAC). #}
                <svg viewBox="0 0 80 80" overflow="visible">
                    <rect x="26" y="14" width="28" height="52" rx="12" fill="#7d8ea0"/>
                    <rect x="30" y="18" width="20" height="44" rx="9" fill="#bfe0ee" opacity=".5"/>
                    <path d="M18 34 q6 -6 12 0 t12 0" fill="none" stroke="#e05341" stroke-width="2.5" stroke-linecap="round"/>
                    <path d="M18 46 q6 -6 12 0 t12 0" fill="none" stroke="#e05341" stroke-width="2.5" stroke-linecap="round" opacity=".7"/>
                </svg>
            {% endif %}
        </div>
        <h2>{{ action.title }}</h2>
    </div>
    <div class="row"><span class="key">Coût</span><span>{{ action.costLabel }}</span></div>
    {% if action.subsidyLabel is not empty %}
        <div class="row"><span class="key">Prime</span><span class="pos">−{{ action.subsidyLabel }}</span></div>
    {% endif %}
    <div class="row"><span class="key">Reste à charge</span><span><strong>{{ action.netCostLabel }}</strong></span></div>
    {% if action.effectLabels is not empty %}
        <div class="effects">
            {% for effect in action.effectLabels %}
                <div>{{ effect }}</div>
            {% endfor %}
        </div>
    {% else %}
        <div class="effects effects-none">Aucun effet mesurable sur votre installation actuelle.</div>
    {% endif %}
    {% if action.adviceMessage is not empty %}
        <p class="quote-advice quote-advice--{{ action.adviceLevel }}">
            <span class="quote-advice-icon">{{ action.adviceLevel == 'caution' ? '⚠️' : '💡' }}</span>
            {{ action.adviceMessage }}
        </p>
    {% endif %}
    <div class="quote-actions">
        <twig:Button label="Payer comptant" action="order" :params="{work: action.work, financing: 'cash'}" class="btn-primary btn-small" :disabled="not action.cashAllowed" />
        {% if action.loanAllowed %}
            <twig:Button label="Éco-PTZ · {{ action.loanMonthlyLabel }}/mois · 20 ans" action="order" :params="{work: action.work, financing: 'loan'}" />
        {% endif %}
    </div>
</div>
