{% extends 'base.html.twig' %}

{% block title %}EcoSim — Ma maison{% endblock %}

{# JavaScript-free slice: skip the importmap entirely. #}
{% block javascripts %}{% endblock %}

{% block stylesheets %}
    <link rel="stylesheet" href="{{ asset('styles/game.css') }}">
{% endblock %}

{% block body %}
<div class="wrap">
    <header class="top">
        <h1>🏠 EcoSim — Ma maison</h1>
        <div class="sub">Jour {{ game.dayNumber }} / {{ game.horizonDays }} · {{ game.dateLabel }} · {{ game.seasonLabel }}</div>
    </header>
    <div class="progress"><span style="width: {{ game.progressPct }}%"></span></div>

    {% if game.finished %}
        <div class="banner">🏁 Partie terminée (horizon atteint). Le bilan de fin arrive dans une prochaine étape.</div>
    {% endif %}

    <div class="grid">
        <div class="card">
            <h2>Météo du jour</h2>
            <div class="big">{{ game.temperatureC|number_format(1, ',', ' ') }}&nbsp;°C</div>
            <div class="row"><span class="k">Nébulosité</span><span>{{ game.cloudPct }} %</span></div>
            <div class="gauge"><span style="width: {{ game.cloudPct }}%; background: var(--cold);"></span></div>
        </div>

        <div class="card">
            <h2>Énergie du jour</h2>
            <div class="row"><span class="k">Production solaire</span><span>{{ game.productionKwh|number_format(1, ',', ' ') }} kWh</span></div>
            <div class="row"><span class="k">Consommation élec.</span><span>{{ game.demandKwh|number_format(1, ',', ' ') }} kWh</span></div>
            {% if game.fuelOilLitres > 0 %}
                <div class="row"><span class="k">Fioul brûlé</span><span>{{ game.fuelOilLitres|number_format(1, ',', ' ') }} L</span></div>
            {% endif %}
            <div class="row"><span class="k">Réseau</span>
                <span>
                    {% if game.gridExportKwh > game.gridImportKwh %}
                        <span class="pos">+{{ (game.gridExportKwh - game.gridImportKwh)|number_format(1, ',', ' ') }} kWh injectés</span>
                    {% else %}
                        <span class="neg">−{{ (game.gridImportKwh - game.gridExportKwh)|number_format(1, ',', ' ') }} kWh soutirés</span>
                    {% endif %}
                </span>
            </div>
        </div>

        <div class="card">
            <h2>Confort thermique</h2>
            <div class="big">{{ game.comfortScorePct }} %</div>
            <div class="gauge"><span style="width: {{ game.comfortScorePct }}%; background: var(--accent);"></span></div>
            <div class="row" style="margin-top:.6rem"><span class="k">Ressenti</span><span>{{ game.feltTemperatureC|number_format(1, ',', ' ') }} °C</span></div>
            <div class="row"><span class="k">Air intérieur</span><span>{{ game.indoorTemperatureC|number_format(1, ',', ' ') }} °C</span></div>
        </div>

        <div class="card">
            <h2>Autosuffisance (jour)</h2>
            <div class="big">{{ game.selfSufficiencyPct }} %</div>
            <div class="gauge"><span style="width: {{ game.selfSufficiencyPct }}%; background: var(--accent);"></span></div>
            <div class="row" style="margin-top:.6rem"><span class="k">Batterie</span><span>{{ game.batteryLevelKwh|number_format(1, ',', ' ') }} / {{ game.batteryCapacityKwh|number_format(0, ',', ' ') }} kWh</span></div>
            <div class="gauge"><span style="width: {{ game.batteryPct }}%; background: var(--warn);"></span></div>
        </div>
    </div>

    <section>
        <h2 class="section">Ma maison — Isolation : {{ game.insulationLabel }} · DPE {{ game.dpeLetter }}</h2>
        <div class="zones">
            <div class="zone">
                <div class="emo">🔆</div>
                <div class="lbl">Toit</div>
                <div class="val">{{ game.solarKwc|number_format(1, ',', ' ') }} kWc</div>
            </div>
            <div class="zone">
                <div class="emo">🔥</div>
                <div class="lbl">Chaudière</div>
                <div class="val">{{ game.heatingLabel }}</div>
            </div>
            <div class="zone">
                <div class="emo">🔋</div>
                <div class="lbl">Garage</div>
                <div class="val">{{ game.batteryCapacityKwh|number_format(0, ',', ' ') }} kWh</div>
            </div>
        </div>
    </section>

    <section>
        <h2 class="section">Depuis le début</h2>
        <div class="card">
            <div class="row"><span class="k">Production cumulée</span><span>{{ game.totalProductionKwh|number_format(1, ',', ' ') }} kWh</span></div>
            <div class="row"><span class="k">Importé du réseau</span><span>{{ game.totalImportKwh|number_format(1, ',', ' ') }} kWh</span></div>
            <div class="row"><span class="k">Exporté (surplus)</span><span>{{ game.totalExportKwh|number_format(1, ',', ' ') }} kWh</span></div>
            <div class="row"><span class="k">Autosuffisance globale</span><span>{{ game.totalSelfSufficiencyPct }} %</span></div>
            <div class="row"><span class="k">Fioul consommé</span><span>{{ game.totalFuelOilLitres|number_format(1, ',', ' ') }} L</span></div>
            <div class="row"><span class="k">Confort moyen</span><span>{{ game.averageComfortPct }} %</span></div>
        </div>
    </section>

    <div class="actions">
        {% if not game.finished %}
            <form method="post" action="{{ path('app_game_advance') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('game') }}">
                <button type="submit" class="btn-primary">Jour suivant →</button>
            </form>
        {% endif %}
        <form method="post" action="{{ path('app_game_reset') }}">
            <input type="hidden" name="_token" value="{{ csrf_token('game') }}">
            <button type="submit" class="btn-ghost">Nouvelle partie</button>
        </form>
    </div>
</div>
{% endblock %}
