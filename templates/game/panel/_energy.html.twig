{# Axe Énergie & climat (coin ↙) : flux du jour, empreinte du logement, météo. #}
<twig:PanelHead title="⚡ Énergie & climat" />
<div class="card">
    <div class="row"><span class="key">Production solaire</span><span>{{ game.productionKwh|number_format(1, ',', ' ') }} kWh</span></div>
    <div class="row"><span class="key">Consommation élec.</span><span>{{ game.demandKwh|number_format(1, ',', ' ') }} kWh</span></div>
    {% if game.fuelOilLitres > 0 %}
        <div class="row"><span class="key">Fioul brûlé<twig:Tip text="{{ game.help.fuelOil }}" /></span><span>{{ game.fuelOilLitres|number_format(1, ',', ' ') }} L</span></div>
    {% endif %}
    {% if game.pelletKg > 0 %}
        <div class="row"><span class="key">Granulés brûlés</span><span>{{ game.pelletKg|number_format(1, ',', ' ') }} kg</span></div>
    {% endif %}
    <div class="row"><span class="key">Autosuffisance<twig:Tip text="{{ game.help.selfSufficiency }}" /></span><span>{{ game.selfSufficiencyPct }} %</span></div>
</div>
<div class="card">
    <h2>Empreinte réelle</h2>
    <div class="row"><span class="key">CO₂ émis depuis le début<twig:Tip text="{{ game.help.co2Emitted }}" /></span><span><strong>{{ game.co2EmittedLabel }}</strong></span></div>
    <p class="panel-note">Ce que vous avez vraiment mis dans l'air (fioul + réseau) — monte jour après jour.</p>
</div>
<div class="card">
    <h2>Empreinte du logement</h2>
    <div class="row"><span class="key">Émissions · étiquette climat</span><span><strong>{{ game.dpeClimateIntensity }}</strong> kgCO₂/m²·an</span></div>
    <div class="row"><span class="key">Consommation · étiquette énergie</span><span><strong>{{ game.dpeEnergyIntensity }}</strong> kWhEP/m²·an</span></div>
    <p class="panel-note">La <em>note</em> du bâti sur une année type · étiquette DPE dans le coin Patrimoine.</p>
</div>
