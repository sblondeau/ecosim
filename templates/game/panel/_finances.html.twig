{% import 'game/_macros.html.twig' as ui %}
{# Axe Finances (coin ↖) : le détail du flux d'argent. #}
<div class="card panel-head"><h2>💶 Finances</h2></div>
<div class="card">
    <div class="big {{ game.savingsNegative ? 'neg' }}">{{ game.savingsLabel }}</div>
    <div class="row"><span class="key">Électricité (jour){{ ui.tip(game.help.electricity) }}</span><span class="neg">−{{ game.electricityCostLabel }}</span></div>
    <div class="row"><span class="key">Fioul (jour)</span><span class="neg">−{{ game.fuelOilCostLabel }}</span></div>
    <div class="row"><span class="key">Revente surplus{{ ui.tip(game.help.surplus) }}</span><span class="pos">+{{ game.surplusRevenueLabel }}</span></div>
    <div class="row"><span class="key">Revenu mensuel</span><span class="pos">+{{ game.monthlyIncomeLabel }}</span></div>
    <div class="row"><span class="key">Dépenses du foyer</span><span class="neg">−{{ game.monthlyExpensesLabel }}</span></div>
    <div class="row"><span class="key">Reste à vivre mensuel{{ ui.tip(game.help.netIncome) }}</span><span>{{ game.monthlyNetIncomeLabel }}{% if game.incomeCreditedToday %} <span class="pos">(crédité)</span>{% endif %}</span></div>
    {% if game.loanActive %}
        <div class="row"><span class="key">Mensualité éco-PTZ (le 1ᵉʳ){{ ui.tip(game.help.ecoPtz) }}</span><span class="neg">−{{ game.loanMonthlyPaymentLabel }}</span></div>
        <div class="row"><span class="key">Dette restante · ~{{ game.loanRemainingYears }} an{{ game.loanRemainingYears > 1 ? 's' }}</span><span>{{ game.loanRemainingLabel }}</span></div>
    {% endif %}
    <div class="row"><span class="key">Taux d'effort énergétique{{ ui.tip(game.help.fuelPoverty) }}</span><span class="{{ game.inFuelPoverty ? 'neg' }}">{{ game.energyEffortPct }} %{% if game.inFuelPoverty %} ⚠️{% endif %}</span></div>
    {% if game.inFuelPoverty %}
        <div class="precarity">⚠️ Foyer en <strong>précarité énergétique</strong> (plus de 8 % du revenu dans l'énergie). Isoler ou changer de chauffage l'en fait sortir.</div>
    {% endif %}
</div>
