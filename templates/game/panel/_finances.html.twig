{# Axe Finances (coin ↖) : le capital, puis le budget mensuel par nature
   (vie / énergie / dette) pour voir clairement où part l'argent. #}
<twig:PanelHead title="💶 Finances" />

<div class="card">
    <div class="key">Épargne</div>
    <div class="big {{ game.savingsNegative ? 'neg' }}">{{ game.savingsLabel }}</div>
    <div class="row"><span class="key">Variation aujourd'hui</span><span class="{{ game.dayNetNegative ? 'neg' : 'pos' }}">{{ game.dayNetLabel }}</span></div>
</div>

<div class="card">
    <h2>Budget mensuel</h2>
    <div class="row"><span class="key">Revenu</span><span class="pos">+{{ game.monthlyIncomeLabel }}</span></div>
    <div class="row"><span class="key">Vie courante</span><span class="neg">−{{ game.monthlyExpensesLabel }}</span></div>
    <div class="row"><span class="key">Énergie · moyenne</span><span class="neg">−{{ game.monthlyEnergyCostLabel }}</span></div>
    {% if game.loanActive %}
        <div class="row"><span class="key">Dette éco-PTZ<twig:Tip text="{{ game.help.ecoPtz }}" /></span><span class="neg">−{{ game.loanMonthlyPaymentLabel }}</span></div>
    {% endif %}
    <div class="row"><span class="key"><strong>Reste à vivre</strong></span><span class="{{ game.monthlyLeftoverNegative ? 'neg' }}"><strong>{{ game.monthlyLeftoverLabel }}</strong></span></div>
    <p class="panel-note">Reste à vivre = revenu − vie courante − énergie − dette. L'énergie est une moyenne mensuelle (la facture réelle est saisonnière, plus salée l'hiver).</p>
</div>

<div class="card">
    <div class="row"><span class="key">Taux d'effort énergétique<twig:Tip text="{{ game.help.fuelPoverty }}" /></span><span class="{{ game.inFuelPoverty ? 'neg' }}">{{ game.energyEffortPct }} %{% if game.inFuelPoverty %} ⚠️{% endif %}</span></div>
    {% if game.inFuelPoverty %}
        <div class="precarity">⚠️ Foyer en <strong>précarité énergétique</strong> (plus de 8 % du revenu dans l'énergie). Isoler ou changer de chauffage l'en fait sortir.</div>
    {% endif %}
    {% if game.loanActive %}
        <div class="row"><span class="key">Dette éco-PTZ restante · ~{{ game.loanRemainingYears }} an{{ game.loanRemainingYears > 1 ? 's' }}</span><span>{{ game.loanRemainingLabel }}</span></div>
    {% endif %}
</div>
