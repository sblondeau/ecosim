{% import 'game/_macros.html.twig' as ui %}
{# Le panneau contextuel d'un emplacement cliqué : ses indicateurs, ses devis. #}
{% set scene = game.scene %}
{% set titles = {
    roof: '🔆 Toit — ' ~ scene.roofLabel,
    walls: '🧱 Isolation — ' ~ scene.insulationLabel,
    heating: (scene.heatingState == 'fioul-broken' ? '🚨 ' : '♨️ ') ~ scene.heatingLabel ~ (scene.heatingState == 'fioul-broken' ? ' — en panne' : ''),
    garage: '🔋 Garage — ' ~ scene.garageLabel,
    living: '🛋️ Séjour',
} %}
{% set worksOfSlot = {
    roof: ['solar_panels'],
    walls: ['insulation'],
    heating: ['boiler_repair', 'heat_pump'],
    garage: ['home_battery'],
    living: [],
} %}

<div class="card panel-head">
    <h2>{{ titles[selected] }}</h2>
</div>

<div class="card">
    {% if selected == 'roof' %}
        <div class="row"><span class="k">Production aujourd'hui</span><span>{{ game.productionKwh|number_format(1, ',', ' ') }} kWh</span></div>
        <div class="row"><span class="k">Nébulosité{{ ui.tip(game.help.cloud) }}</span><span>{{ game.cloudPct }} %</span></div>
        <div class="row"><span class="k">Exporté aujourd'hui{{ ui.tip(game.help.surplus) }}</span><span>{{ game.gridExportKwh|number_format(1, ',', ' ') }} kWh</span></div>
    {% elseif selected == 'walls' %}
        <div class="row"><span class="k">DPE</span><span><strong>{{ game.dpeLetter }}</strong></span></div>
        <div class="row"><span class="k">Valeur du bien{{ ui.tip(game.help.propertyValue) }}</span><span>{{ game.propertyValueLabel }}</span></div>
        <div class="row"><span class="k">Confort ressenti{{ ui.tip(game.help.comfort) }}</span><span>{{ game.feltTemperatureC|number_format(1, ',', ' ') }} °C</span></div>
    {% elseif selected == 'heating' %}
        {% if game.boilerBroken %}
            <div class="row"><span class="k">État</span><span class="neg"><strong>En panne</strong> — appoint électrique forcé</span></div>
            <div class="row"><span class="k">Élec. de chauffage (jour)</span><span class="neg">{{ game.heatingElectricityKwh|number_format(1, ',', ' ') }} kWh</span></div>
        {% else %}
            {% if game.fuelOilLitres > 0 %}
                <div class="row"><span class="k">Fioul brûlé (jour){{ ui.tip(game.help.fuelOil) }}</span><span>{{ game.fuelOilLitres|number_format(1, ',', ' ') }} L</span></div>
            {% endif %}
            {% if game.heatingElectricityKwh > 0 %}
                <div class="row"><span class="k">Élec. de chauffage (jour)</span><span>{{ game.heatingElectricityKwh|number_format(1, ',', ' ') }} kWh</span></div>
            {% endif %}
        {% endif %}
        <div class="row"><span class="k">Air intérieur</span><span>{{ game.indoorTemperatureC|number_format(1, ',', ' ') }} °C</span></div>
    {% elseif selected == 'garage' %}
        {% if game.batteryCapacityKwh > 0 %}
            <div class="row"><span class="k">Batterie → maison ce soir</span><span>{{ game.batteryDischargedKwh|number_format(1, ',', ' ') }} kWh</span></div>
            <div class="gauge"><span style="width: {{ game.batteryCapacityKwh > 0 ? (100 * game.batteryDischargedKwh / game.batteryCapacityKwh)|round : 0 }}%; background: var(--warn);"></span></div>
        {% else %}
            <div class="row"><span class="k">Batterie</span><span>—</span></div>
        {% endif %}
        <div class="row"><span class="k">Autosuffisance (jour){{ ui.tip(game.help.selfSufficiency) }}</span><span>{{ game.selfSufficiencyPct }} %</span></div>
    {% elseif selected == 'living' %}
        <div class="row"><span class="k">Confort thermique{{ ui.tip(game.help.comfort) }}</span><span>{{ game.comfortScorePct }} %</span></div>
        <div class="gauge"><span style="width: {{ game.comfortScorePct }}%; background: var(--accent);"></span></div>
        <div class="row" style="margin-top:.5rem"><span class="k">Ressenti</span><span>{{ game.feltTemperatureC|number_format(1, ',', ' ') }} °C</span></div>
        <div class="row"><span class="k">Air intérieur</span><span>{{ game.indoorTemperatureC|number_format(1, ',', ' ') }} °C</span></div>
    {% endif %}
</div>

{% if selected == 'living' and not game.finished and not game.boilerBroken %}
    <div class="card thermostat-panel">
        <h2>Thermostat{{ ui.tip(game.help.setpoint) }}</h2>
        <div class="thermo-dial">
            <button type="button" class="btn-ghost thermo-btn" {{ game.setpointCanDown ? '' : 'disabled' }} aria-label="Baisser"
                    data-action="live#action" data-live-action-param="adjustSetpoint" data-live-delta-param="-1">−</button>
            <div class="thermo-value">{{ game.setpointC }} °C</div>
            <button type="button" class="btn-ghost thermo-btn" {{ game.setpointCanUp ? '' : 'disabled' }} aria-label="Monter"
                    data-action="live#action" data-live-action-param="adjustSetpoint" data-live-delta-param="1">+</button>
        </div>
        {% if game.setpointDownEffectLabel is not empty %}<div class="thermo-effect neg">−1 °C : {{ game.setpointDownEffectLabel }}</div>{% endif %}
        {% if game.setpointUpEffectLabel is not empty %}<div class="thermo-effect pos">+1 °C : {{ game.setpointUpEffectLabel }}</div>{% endif %}
        {% if game.setpointBelowHealthy %}<div class="precarity">🥶 Sous 18 °C : sous-chauffage. Les habitants souffrent du froid (plancher santé OMS).</div>{% endif %}
    </div>
{% endif %}

{% if not game.finished %}
    {% for work in worksOfSlot[selected] %}
        {% if game.actions[work] is defined %}
            {{ ui.quote_card(game.actions[work]) }}
        {% endif %}
    {% endfor %}
{% endif %}
