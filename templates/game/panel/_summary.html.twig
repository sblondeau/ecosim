{% import 'game/_macros.html.twig' as ui %}
{# Le panneau par défaut : les finances toujours visibles, le reste replié. #}
<div class="card">
    <h2>Finances</h2>
    <div class="big {{ game.savingsNegative ? 'neg' }}">{{ game.savingsLabel }}</div>
    <div class="row"><span class="k">Électricité (jour){{ ui.tip(game.help.electricity) }}</span><span class="neg">−{{ game.electricityCostLabel }}</span></div>
    <div class="row"><span class="k">Fioul (jour)</span><span class="neg">−{{ game.fuelOilCostLabel }}</span></div>
    <div class="row"><span class="k">Revente surplus{{ ui.tip(game.help.surplus) }}</span><span class="pos">+{{ game.surplusRevenueLabel }}</span></div>
    <div class="row"><span class="k">Revenu mensuel</span><span class="pos">+{{ game.monthlyIncomeLabel }}</span></div>
    <div class="row"><span class="k">Dépenses du foyer</span><span class="neg">−{{ game.monthlyExpensesLabel }}</span></div>
    <div class="row"><span class="k">Reste à vivre mensuel{{ ui.tip(game.help.netIncome) }}</span><span>{{ game.monthlyNetIncomeLabel }}{% if game.incomeCreditedToday %} <span class="pos">(crédité)</span>{% endif %}</span></div>
    {% if game.loanActive %}
        <div class="row"><span class="k">Mensualité éco-PTZ (le 1ᵉʳ){{ ui.tip(game.help.ecoPtz) }}</span><span class="neg">−{{ game.loanMonthlyPaymentLabel }}</span></div>
        <div class="row"><span class="k">Dette restante · encore ~{{ game.loanRemainingYears }} an{{ game.loanRemainingYears > 1 ? 's' }}</span><span>{{ game.loanRemainingLabel }}</span></div>
    {% endif %}
    <div class="row"><span class="k">Taux d'effort énergétique{{ ui.tip(game.help.fuelPoverty) }}</span><span class="{{ game.inFuelPoverty ? 'neg' }}">{{ game.energyEffortPct }} %{% if game.inFuelPoverty %} ⚠️{% endif %}</span></div>
    {% if game.inFuelPoverty %}
        <div class="precarity">⚠️ Foyer en <strong>précarité énergétique</strong> (plus de 8 % du revenu part dans l'énergie). Isoler ou changer de chauffage l'en fait sortir.</div>
    {% endif %}
</div>

<details class="card" open>
    <summary>Aujourd'hui — énergie & confort</summary>
    <div class="row"><span class="k">Production solaire</span><span>{{ game.productionKwh|number_format(1, ',', ' ') }} kWh</span></div>
    <div class="row"><span class="k">Consommation élec.</span><span>{{ game.demandKwh|number_format(1, ',', ' ') }} kWh</span></div>
    {% if game.fuelOilLitres > 0 %}
        <div class="row"><span class="k">Fioul brûlé{{ ui.tip(game.help.fuelOil) }}</span><span>{{ game.fuelOilLitres|number_format(1, ',', ' ') }} L</span></div>
    {% endif %}
    <div class="row"><span class="k">Autosuffisance{{ ui.tip(game.help.selfSufficiency) }}</span><span>{{ game.selfSufficiencyPct }} %</span></div>
    <div class="row"><span class="k">Confort thermique{{ ui.tip(game.help.comfort) }}</span><span>{{ game.comfortScorePct }} %</span></div>
    <div class="gauge"><span style="width: {{ game.comfortScorePct }}%; background: var(--accent);"></span></div>
</details>

<details class="card">
    <summary>Météo — {{ game.temperatureC|number_format(1, ',', ' ') }} °C, {{ game.cloudPct }} % de nuages{{ ui.tip(game.help.cloud) }}</summary>
    {% set spark = game.weatherSparkline %}
    {% if spark.days > 1 %}
        <div class="spark">
            <div class="spark-head">
                <span class="k">{{ spark.days }} derniers jours</span>
                <span class="k">{{ spark.temperatureMinLabel }} … {{ spark.temperatureMaxLabel }}</span>
            </div>
            <svg viewBox="0 0 100 28" preserveAspectRatio="none" role="img" aria-label="Température et nébulosité des {{ spark.days }} derniers jours">
                <polyline points="{{ spark.cloudPoints }}" fill="none" stroke="var(--cold)" stroke-width="0.7" opacity="0.55"/>
                <polyline points="{{ spark.temperaturePoints }}" fill="none" stroke="var(--warn)" stroke-width="1"/>
            </svg>
            <div class="spark-legend">
                <span><i style="background: var(--warn);"></i> température</span>
                <span><i style="background: var(--cold);"></i> nébulosité</span>
            </div>
        </div>
    {% endif %}
</details>

<details class="card">
    <summary>Depuis le début</summary>
    <div class="row"><span class="k">Production cumulée</span><span>{{ game.totalProductionKwh|number_format(1, ',', ' ') }} kWh</span></div>
    <div class="row"><span class="k">Importé / exporté</span><span>{{ game.totalImportKwh|number_format(1, ',', ' ') }} / {{ game.totalExportKwh|number_format(1, ',', ' ') }} kWh</span></div>
    <div class="row"><span class="k">Autosuffisance globale</span><span>{{ game.totalSelfSufficiencyPct }} %</span></div>
    <div class="row"><span class="k">Fioul consommé</span><span>{{ game.totalFuelOilLitres|number_format(1, ',', ' ') }} L</span></div>
    <div class="row"><span class="k">Confort moyen</span><span>{{ game.averageComfortPct }} %</span></div>
    <div class="row"><span class="k">Facture électricité</span><span class="neg">−{{ game.totalElectricityCostLabel }}</span></div>
    <div class="row"><span class="k">Facture fioul</span><span class="neg">−{{ game.totalFuelOilCostLabel }}</span></div>
    <div class="row"><span class="k">Revente cumulée</span><span class="pos">+{{ game.totalSurplusRevenueLabel }}</span></div>
    <div class="row"><span class="k">Coût énergie net</span><span><strong>{{ game.totalNetEnergyCostLabel }}</strong></span></div>
</details>

<details class="card">
    <summary>Patrimoine{{ ui.tip(game.help.propertyValue) }}</summary>
    <div class="row"><span class="k">Valeur du bien (DPE {{ game.dpeLetter }})</span><span>{{ game.propertyValueLabel }}</span></div>
    <div class="row"><span class="k">Nature</span><span class="k">réalisable à la revente uniquement</span></div>
</details>

{% if game.actions is not empty and not game.finished %}
    <div class="card">
        <h2>Travaux disponibles{{ ui.tip(game.help.worksEstimate) }}</h2>
        <div class="works-links">
            {% set slotOfWork = {insulation: 'walls', heat_pump: 'heating', boiler_repair: 'heating', solar_panels: 'roof', home_battery: 'garage'} %}
            {% for action in game.actions %}
                <button type="button" class="btn-ghost btn-small"
                        data-action="click->live#action" data-live-action-param="selectSlot"
                        data-live-slot-param="{{ slotOfWork[action.work] }}">{{ action.title }} · {{ action.netCostLabel }}</button>
            {% endfor %}
        </div>
    </div>
{% endif %}

<div class="panel-footer">
    <button type="button" class="btn-ghost btn-small"
            data-action="live#action" data-live-action-param="reset">Nouvelle partie</button>
</div>
